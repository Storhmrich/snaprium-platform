# ========================
# Snaprium Environment Variables
# ========================

# === OpenAI ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Firebase ===
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=xxxxxxxxxxxx
VITE_FIREBASE_APP_ID=1:xxxxxxxxxxxx:web:xxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# === Paddle (LIVE - Now Approved) ===
VITE_PADDLE_CLIENT_TOKEN=live_your_client_side_token_here
VITE_PADDLE_ENV=production

# ========================
# Backend / Vercel Variables (Not prefixed with VITE)
# ========================

# Paddle Webhook Secret (Copy from Paddle Dashboard → Developer Tools → Webhooks)
PADDLE_WEBHOOK_SECRET=your_webhook_secret_here